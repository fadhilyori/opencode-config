{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "autoupdate": true,
  "share": "disabled",
  "model": "minimax-coding-plan/MiniMax-M2.7",
  "small_model": "minimax-coding-plan/MiniMax-M2.5",
  "disabled_providers": [],
  "permission": {
    "bash": {
      "git status *": "allow",
      "git diff *": "allow",
      "grep *": "allow"
    }
  },
  "provider": {},
  "mcp": {
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp/oauth"
    },
    "gh_grep": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.grep.app"
    },
    "MiniMax": {
      "enabled": true,
      "type": "local",
      "command": ["uvx", "minimax-coding-plan-mcp", "-y"],
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_TOKEN_PLAN_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimax.io"
      }
    }
  },
  "compaction": {
    "auto": true,
  },
}
